{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "rut-generator",
  "title": "RUT Generator",
  "description": "Generate valid Chilean RUTs for development and testing.",
  "icon": "icon.png",
  "author": "esteban03",
  "categories": [
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "generate-rut",
      "title": "Generate RUT",
      "description": "Generate a list of valid Chilean RUTs and copy them to the clipboard.",
      "mode": "view",
      "preferences": [
        {
          "name": "defaultFormat",
          "title": "Default Format",
          "description": "Format used when generating RUTs.",
          "type": "dropdown",
          "required": true,
          "default": "dots",
          "data": [
            {
              "title": "With dots and dash (12.345.678-5)",
              "value": "dots"
            },
            {
              "title": "Without dots, with dash (12345678-5)",
              "value": "dash"
            },
            {
              "title": "Without dots or dash (123456785)",
              "value": "plain"
            }
          ]
        }
      ]
    }
  ],
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@raycast/api": "^1.100.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
